# ============================================================================
# CleanTenant — Ortam Değişkenleri Şablonu
# ============================================================================
# Kullanım: cp .env.example .env  (sonra .env içindeki değerleri düzenle)
# ⚠️ .env dosyası Git'e ASLA commit edilmez!
# ============================================================================

# ── POSTGRESQL (ANA VERİTABANI) ───────────────────────────────────────
DB_PORT=5432
DB_NAME=cleantenant_main
DB_USER=cleantenant
DB_PASSWORD=<GÜÇLÜ_ŞİFRE>

# ── POSTGRESQL (AUDIT VERİTABANI) ─────────────────────────────────────
AUDIT_DB_PORT=5433
AUDIT_DB_NAME=cleantenant_audit
AUDIT_DB_USER=cleantenant
AUDIT_DB_PASSWORD=<GÜÇLÜ_ŞİFRE>

# ── REDIS ──────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=<GÜÇLÜ_ŞİFRE>

# ── PGADMIN ───────────────────────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@cleantenant.com
PGADMIN_PASSWORD=<GÜÇLÜ_ŞİFRE>

# ── SEQ (Log Sunucusu) ────────────────────────────────────────────────
SEQ_PORT=5341

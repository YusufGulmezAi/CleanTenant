{
  "CleanTenant": {
    "General": {
      "DefaultTimeZone": "Europe/Istanbul",
      "DateFormat": "dd.MM.yyyy",
      "DateTimeFormat": "dd.MM.yyyy HH:mm:ss"
    },
    "Jwt": {
      "Issuer": "CleanTenant",
      "Audience": "CleanTenant",
      "AccessTokenExpirationMinutes": 15,
      "RefreshTokenExpirationDays": 7
    },
    "Session": {
      "EnforceSingleSession": true,
      "ValidateDeviceFingerprint": true,
      "ValidateIpAddress": true,
      "SessionCheckIntervalSeconds": 30
    },
    "AccessPolicy": {
      "EnableIpWhitelist": false,
      "EnableTimeRestriction": false,
      "EnableRateLimit": true,
      "DefaultRateLimitPerMinute": 60,
      "EnableIpBlacklist": true
    },
    "UserMonitoring": {
      "EnableRealTimeBlocking": true,
      "EnableForceLogout": true
    },
    "PasswordPolicy": {
      "MinimumLength": 8,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireSpecialCharacter": true,
      "PasswordHistoryCount": 5,
      "PasswordExpirationDays": 0,
      "MaxFailedAccessAttempts": 5,
      "LockoutDurationMinutes": 15,
      "PasswordResetTokenExpirationMinutes": 15
    },
    "TwoFactor": {
      "CodeLength": 6,
      "CodeExpirationMinutes": 5,
      "MaxFailedAttempts": 3,
      "EnableEmailFallback": true
    },
    "Backup": {
      "BackupDirectory": "./backups",
      "RetentionDays": 30,
      "AutoBackupCron": ""
    },
    "EmailSettings": {
      "Enabled": true,
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "",
      "Password": "",
      "FromAddress": "",
      "FromName": "CleanTenant",
      "UseSsl": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 4
  },
  "AllowedHosts": "*"
}

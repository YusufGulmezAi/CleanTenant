@page "/"
@attribute [Authorize]
@inject ApiClient Api

<div class="ct-page-header">
    <div>
        <div class="ct-page-title">Dashboard</div>
        <div class="ct-breadcrumb">Ana Sayfa / Dashboard</div>
    </div>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadData">
        Yenile
    </MudButton>
</div>

@* ── Stat Kartları (AdminLTE tarzı) ─────────────────────────────── *@
<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Tenant" Value="@_tenantCount" Icon="@Icons.Material.Filled.CorporateFare"
                  Color="Color.Primary" Change="+2 bu ay" IsPositive="true" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Şirket" Value="@_companyCount" Icon="@Icons.Material.Filled.Store"
                  Color="Color.Secondary" Change="+5 bu ay" IsPositive="true" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Kullanıcı" Value="@_userCount" Icon="@Icons.Material.Filled.People"
                  Color="Color.Info" Change="+12 bu ay" IsPositive="true" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <StatCard Title="Aktif Oturum" Value="@_sessionCount" Icon="@Icons.Material.Filled.Devices"
                  Color="Color.Success" Change="Şu an" IsPositive="true" />
    </MudItem>
</MudGrid>

@* ── İkinci Satır: Güvenlik + Hızlı Erişim ──────────────────────── *@
<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="12" md="8">
        <MudPaper Class="ct-card pa-4" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Son İşlemler</MudText>
            <MudSimpleTable Dense="true" Hover="true" Class="ct-table">
                <thead>
                    <tr>
                        <th>Tarih</th>
                        <th>Kullanıcı</th>
                        <th>İşlem</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _recentActivities)
                    {
                        <tr>
                            <td>@item.Time</td>
                            <td>@item.User</td>
                            <td>@item.Action</td>
                            <td>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(item.Success ? Color.Success : Color.Error)"
                                         Class="ct-chip">
                                    @(item.Success ? "Başarılı" : "Başarısız")
                                </MudChip>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="ct-card pa-4" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Hızlı Erişim</MudText>
            <MudStack Spacing="2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.PersonAdd" Href="/users"
                           Style="justify-content: flex-start;">
                    Kullanıcı Ekle
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.AddBusiness" Href="/tenants"
                           Style="justify-content: flex-start;">
                    Tenant Oluştur
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Security" Href="/access-policies"
                           Style="justify-content: flex-start;">
                    Erişim Politikası
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Settings" Href="/settings"
                           Style="justify-content: flex-start;">
                    Sistem Ayarları
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudPaper Class="ct-card pa-4 mt-3" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-2">Sistem Bilgisi</MudText>
            <MudStack Spacing="1">
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2" Color="Color.Default">API</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ct-chip">Çalışıyor</MudChip>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">Redis</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ct-chip">Bağlı</MudChip>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">PostgreSQL</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ct-chip">Bağlı</MudChip>
                </div>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string _tenantCount = "0";
    private string _companyCount = "0";
    private string _userCount = "0";
    private string _sessionCount = "0";

    private List<ActivityItem> _recentActivities = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // Placeholder veriler — API bağlanınca gerçek veriler gelecek
        _tenantCount = "3";
        _companyCount = "12";
        _userCount = "47";
        _sessionCount = "8";

        _recentActivities =
        [
            new("14:32", "admin@cleantenant.com", "Login (2FA)", true),
            new("14:28", "ahmet@test.com", "Tenant oluşturuldu", true),
            new("14:15", "192.168.1.50", "Başarısız login denemesi", false),
            new("13:55", "admin@cleantenant.com", "Erişim politikası güncellendi", true),
            new("13:42", "mehmet@firma.com", "Şifre değiştirildi", true),
        ];

        await Task.CompletedTask;
    }

    private record ActivityItem(string Time, string User, string Action, bool Success);
}
